# ==============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE - SMART INVOICE EXTRACTOR
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database & Cache Infrastructure
# ------------------------------------------------------------------------------
# MongoDB connection URL (Atlas or Local fallback)
MONGODB_URI=mongodb://localhost:27017/invoice_db

# Redis connection URL (Upstash or Local fallback)
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# 2. Authentication & Authorization
# ------------------------------------------------------------------------------
# JWT secret key for signature validation
JWT_SECRET=replace_with_a_long_random_secret

# JWT token lifespan (e.g. 7d, 24h)
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# 3. AI & LLM Providers
# ------------------------------------------------------------------------------
# Gemini API Key (Gemini 2.0 Flash Lite digital routing)
GEMINI_API_KEY=your_gemini_api_key_here

# Together AI or OpenRouter API Key (Qwen 2.5 VL scanned / Llama 3.2 Vision fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ------------------------------------------------------------------------------
# 4. AI Observability & Monitoring
# ------------------------------------------------------------------------------
# Langfuse API public keys (client-facing metadata)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here

# Langfuse API secret keys (server trace posting)
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here

# Langfuse Server base endpoint URL
LANGFUSE_HOST=https://cloud.langfuse.com
# ------------------------------------------------------------------------------
# 5. File Object Storage
# ------------------------------------------------------------------------------
# Storage URL (e.g. Cloudinary or Supabase Storage bucket paths)
SUPABASE_URL=https://your-project-ref.supabase.co/rest/v1/
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_STORAGE_BUCKET=invoice-files

# ------------------------------------------------------------------------------
# 6. Gateway Configuration
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
