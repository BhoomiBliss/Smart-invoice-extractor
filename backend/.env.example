# Server Configuration
PORT=5001
NODE_ENV=production

# AI Model Configuration (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
PRIMARY_MODEL=google/gemini-2.0-flash-lite-001
SECONDARY_MODEL=qwen/qwen-2.5-vl-72b-instruct
